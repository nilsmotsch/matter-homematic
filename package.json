{
  "name": "matter-homematic",
  "version": "1.0.0",
  "description": "A Matter bridge for Homematic CCU3/RaspberryMatic - expose your Homematic devices to Matter ecosystems",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint 'src/**/*.ts'",
    "test": "jest"
  },
  "keywords": [
    "matter",
    "homematic",
    "ccu3",
    "raspberrymatic",
    "smart-home",
    "homekit",
    "google-home",
    "alexa",
    "smarthings"
  ],
  "author": "Homematic Community",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/homematic-community/matter-homematic"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@matter/main": "^0.16.11",
    "@matter/nodejs": "^0.16.11",
    "xmlrpc": "^1.3.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/xmlrpc": "^1.3.10",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1"
  }
}
