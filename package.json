{
  "name": "matter-homematic",
  "version": "0.10.0",
  "description": "A Matter bridge for Homematic CCU3/RaspberryMatic - expose your Homematic devices to Matter ecosystems",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "postinstall": "patch-package",
    "build": "tsc",
    "build:addon": "bash scripts/build-addon.sh",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint 'src/**/*.ts'",
    "test": "jest",
    "test:ccu": ".venv/bin/python3 -m pydevccu",
    "dev:test": "ts-node src/index.ts --config=config.test.json"
  },
  "keywords": [
    "matter",
    "homematic",
    "ccu3",
    "raspberrymatic",
    "smart-home",
    "homekit",
    "google-home",
    "alexa",
    "smarthings"
  ],
  "author": "Nils Motsch",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nilsmotsch/matter-homematic"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@matter/main": "^0.16.11",
    "@matter/nodejs": "^0.16.11",
    "winston": "^3.11.0",
    "xmlrpc": "^1.3.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/xmlrpc": "^1.3.10",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "patch-package": "^8.0.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
